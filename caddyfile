# HTTPS reverse proxy (runs on host, not inside Docker)
# Start command: caddy run --config Caddyfile
#
# Usage:
#   1. docker compose up -d    (Start App + MySQL + Redis)
#   2. caddy run --config Caddyfile  (Start HTTPS proxy)
#   3. Open https://localhost:4443 or https://your-ip:4443
#
# Modify the IP below to your local network IP (check with ifconfig en0)

localhost:1443, https://192.168.31.218:1443 {
    handle /admin/queues* {
        reverse_proxy localhost:13010
    }
    handle {
        reverse_proxy localhost:13000
    }
    tls internal
}